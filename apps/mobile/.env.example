# Copy to apps/mobile/.env — EXPO_PUBLIC_* values are inlined into the app bundle.
# The Supabase anon key is safe to ship in a client.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend API base — defaults to production if unset.
EXPO_PUBLIC_API_BASE=https://www.kryptoscronos.com

# RevenueCat (mobile IAP) — public SDK keys, safe to ship in the client.
# From the RevenueCat dashboard → Project → API keys (Apple / Google).
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_your_ios_key
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_your_android_key
