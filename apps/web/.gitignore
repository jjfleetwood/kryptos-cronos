# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — never commit secrets
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
# translation working/batch files (intermediate files used during generation)
src/data/translations/ctf-quiz-*-part*.json
src/data/translations/ctf-quiz-fr-[0-9].json
src/data/translations/ctf-quiz-de-missing.json
src/data/translations/ctf-quiz-de-final.json
src/data/translations/hi-p*.json
src/data/translations/pt-p*.json
src/data/translations/*-p[0-9]*.json
src/data/translations/merge-*.js
src/data/translations/batches/
src/data/ctf-quiz-batches/
src/data/audit-quiz-batches/
fix-pl-quotes.js
src/messages/_missing-*.json
next-env.d.ts

.vercel
