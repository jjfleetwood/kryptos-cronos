# Copy to .env.local and fill in real values. Never commit .env.local.

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Auth secrets — generate with: node -e "require('crypto').randomBytes(32).toString('hex')"
ADMIN_SECRET=replace-with-64-char-hex
SESSION_SECRET=replace-with-64-char-hex

# Admin account
ADMIN_USERNAME=your-admin-username
ADMIN_EMAIL=your-email@example.com

# Email (Resend)
RESEND_API_KEY=re_your_resend_key

# AI (Anthropic)
ANTHROPIC_API_KEY=sk-ant-your-key

# Supabase (parallel auth + mobile bearer-token verification) — all server-side
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRO_MONTHLY_PRICE_ID=price_your_monthly_id
STRIPE_PRO_YEARLY_PRICE_ID=price_your_yearly_id

# RevenueCat (mobile IAP) — set this same value as the Authorization header on the
# RevenueCat dashboard webhook (Project → Webhooks). Verifies inbound webhooks.
REVENUECAT_WEBHOOK_AUTH=replace-with-random-secret

# Local dev only
APP_URL=http://localhost:3000
